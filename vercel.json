{
  "version": 2,
  "functions": {
    "api/estimate.js": {
      "maxDuration": 30
    },
    "api/travel-distance.js": {
      "maxDuration": 15
    },
    "api/custom-quote.js": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *.fishbeckinnovations.com"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/estimate", "destination": "/index.html" },
    { "source": "/tools", "destination": "/tools.html" },
    { "source": "/tools/mulch-calculator", "destination": "/mulch-calculator.html" },
    { "source": "/tools/paint-calculator", "destination": "/paint-calculator.html" },
    { "source": "/tools/drywall-calculator", "destination": "/drywall-calculator.html" },
    { "source": "/tools/flooring-calculator", "destination": "/flooring-calculator.html" },
    { "source": "/tools/concrete-calculator", "destination": "/concrete-calculator.html" },
    { "source": "/tools/fence-calculator", "destination": "/fence-calculator.html" },
    { "source": "/tools/pavers-calculator", "destination": "/pavers-calculator.html" },
    { "source": "/tools/sod-calculator", "destination": "/sod-calculator.html" },
    { "source": "/tools/baseboard-calculator", "destination": "/baseboard-calculator.html" },
    { "source": "/tools/wallpaper-calculator", "destination": "/wallpaper-calculator.html" },
    { "source": "/tools/salt-calculator", "destination": "/salt-calculator.html" },
    { "source": "/tools/square-footage-calculator", "destination": "/room-area-calculator.html" },
    { "source": "/tools/unit-turn-calculator", "destination": "/unit-turn-calculator.html" },
    { "source": "/tools/snow-removal-calculator", "destination": "/snow-calculator.html" },
    { "source": "/tools/repair-replace-calculator", "destination": "/repair-replace-calculator.html" },
    { "source": "/tools/fix-and-flip-calculator", "destination": "/flip-calculator.html" },
    { "source": "/tools/diy-vs-hire-calculator", "destination": "/diy-calculator.html" },
    { "source": "/tools/project-schedule-calculator", "destination": "/schedule-calculator.html" },
    { "source": "/tools/tool-rental-calculator", "destination": "/tool-rental-calculator.html" },
    { "source": "/tools/3d-print-calculator", "destination": "/print3d-calculator.html" },
    { "source": "/tools/property-assessment-calculator", "destination": "/property-assessment.html" },
    { "source": "/tools/custom-quote", "destination": "/custom-quote.html" }
  ]
}
