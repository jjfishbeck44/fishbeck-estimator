# .env.example — copy to .env.local for local development
ANTHROPIC_API_KEY=sk-ant-your-key-here
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Custom-quote email (Resend). Without these, the custom-quote form falls back
# to opening the visitor's email client (mailto) instead of sending server-side.
RESEND_API_KEY=re_your-resend-key-here
# Optional: a verified sender. Defaults to Resend's onboarding@resend.dev until
# you verify your own domain in Resend.
RESEND_FROM=Fishbeck Innovations <quotes@fishbeckinnovations.com>

# Property-assessment travel distance uses OpenStreetMap (no key required).
